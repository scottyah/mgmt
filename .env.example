# =============================================================================
# OSA Management Suite — Environment Configuration
# Copy to .env and fill in values before running.
# =============================================================================

# --- Required in production ---------------------------------------------------

# Flask session signing key. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encrypting certificate private keys at rest. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Changing this after storing certs makes existing encrypted keys unrecoverable.
FERNET_KEY=

# --- Auth ---------------------------------------------------------------------

AUTH_USERNAME=admin

# Werkzeug password hash. Generate with:
#   python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
AUTH_PASSWORD_HASH=

# --- Database -----------------------------------------------------------------

# SQLite (default):
DATABASE_URL=sqlite:///osa.db

# PostgreSQL (future):
# DATABASE_URL=postgresql://user:pass@host:5432/osa

# --- Optional -----------------------------------------------------------------

# Set to "true" when behind TLS
SESSION_COOKIE_SECURE=false

# Enable Flask debug mode (never in production)
FLASK_DEBUG=false
