# Flask secret key for sessions
SECRET_KEY=change-me-to-a-random-string

# Fernet key for encrypting private keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# Database URI (default: sqlite:///osa.db)
SQLALCHEMY_DATABASE_URI=sqlite:///osa.db

# Auth credentials
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=
